<Window x:Class="Ome.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuration Menu" Height="300" Width="300" Background="Black">


    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
        <!-- Load Config Button -->
        <Button Content="Load Config" Width="150" Height="40" Click="LoadConfigButton_Click" Margin="10"/>

        <!-- Save Config Button -->
        <Button Content="Save Config" Width="150" Height="40" Click="SaveConfigButton_Click" Margin="10"/>

        <!-- ReplayGain toggle (applies live; persisted in settings.json) -->
        <CheckBox x:Name="ReplayGainCheckBox"
                  Content="Use ReplayGain"
                  Foreground="White"
                  HorizontalAlignment="Center"
                  Margin="10"
                  Checked="ReplayGainCheckBox_Changed"
                  Unchecked="ReplayGainCheckBox_Changed"/>

        <!-- Exit Application Button -->
        <Button Content="Exit Application" Width="150" Height="40" Click="ExitApplicationButton_Click" Margin="10"/>
    </StackPanel>
</Window>
